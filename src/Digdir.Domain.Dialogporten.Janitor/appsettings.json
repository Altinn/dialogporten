{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Error",
        "Digdir.Domain.Dialogporten": "Information"
      }
    }
  },
  "Infrastructure": {
    "AltinnCdn": {
      "BaseUri": "https://altinncdn.no/"
    },
    "DialogSearch": {
      // Set to 0 to use the Npgsql/provider default command timeout.
      "UpsertCommandTimeoutSeconds": 5
    },
    "Warmup": {
      "Enabled": true,
      "TimeoutSeconds": 60,
      "DbConnectionsToOpen": 4,
      "DbConnectionParallelism": 2,
      "RunEndUserSearch": false
    }
  },
  "AllowedHosts": "*"
}
