{
    "openApiPath": "../Digdir.Domain.Dialogporten.WebApi/bin/Release/net10.0/swagger.json",
    "namespace": "Altinn.ApiClients.Dialogporten.Features.V1.ServiceOwner",
    "outputFolder": "Features/V1/ServiceOwner",
    "operationNameGenerator": "Default",
    "trimUnusedSchema": true,
    "multipleInterfaces": "ByEndpoint",
    "includeTags": [
        "Serviceowner"
    ],
    "useCancellationTokens": true,
    "returnIApiResponse": true,
    "useDynamicQuerystringParameters": true,
    "outputFilename": "RefitterInterface.cs",
    "codeGeneratorSettings": {
        "dateFormat": "yyyy-MM-ddTHH:mm:ssZ"
    }
}
