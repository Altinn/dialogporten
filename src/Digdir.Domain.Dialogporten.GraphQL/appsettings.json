{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "Fatal",

        // This enables logging of parties/service tuples counts being fed into the search SQL query
        "Digdir.Domain.Dialogporten.Infrastructure.Persistence.Repositories.DialogSearch.EndUser": "Information"
      }
    }
  },
  "Infrastructure": {
    "AltinnCdn": {
      "BaseUri": "https://altinncdn.no/"
    },
    "DialogSearch": {
      // Set to 0 to use the Npgsql/provider default command timeout.
      "UpsertCommandTimeoutSeconds": 5
    }
  },
  "Application": {
    "Limits": {
      "EndUserSearch": {
        "MaxPartyFilterValues": 20,
        "MaxServiceResourceFilterValues": 20,
        "MaxOrgFilterValues": 20,
        "MaxExtendedStatusFilterValues": 20,
        "MinServiceDrivenStrategyPartyCount": 100
      },
      "ServiceOwnerSearch": {
        "MaxPartyFilterValues": 20,
        "MaxServiceResourceFilterValues": 20,
        "MaxExtendedStatusFilterValues": 20
      }
    }
  },
  "AllowedHosts": "*"
}
