{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Npgsql.Internal": "Fatal",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Fatal",
        "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "Fatal",

        // This enables logging of parties/service tuples counts being fed into the search SQL query
        "Digdir.Domain.Dialogporten.Infrastructure.Persistence.Repositories.DialogSearch.EndUser": "Information",

        // WARNING! This is critical to cost management tracking and should not be disabled.
        "Digdir.Domain.Dialogporten.Application.Common.Behaviours.FeatureMetric.LoggingFeatureMetricDeliveryContext": "Information"
      }
    }
  },
  "Infrastructure": {
    "AltinnCdn": {
      "BaseUri": "https://altinncdn.no/"
    },
    "DialogSearch": {
      // Set to 0 to use the Npgsql/provider default command timeout.
      "UpsertCommandTimeoutSeconds": 5
    },
    "Warmup": {
      "Enabled": true,
      "TimeoutSeconds": 60,
      "DbConnectionsToOpen": 4,
      "DbConnectionParallelism": 2,
      "RunEndUserSearch": true
    }
  },
  "Application": {
    "Limits": {
      "EndUserSearch": {
        "MaxPartyFilterValues": 100,
        "MaxServiceResourceFilterValues": 20,
        "MaxOrgFilterValues": 20,
        "MaxExtendedStatusFilterValues": 20,
        "MinServiceDrivenStrategyPartyCount": 100,
        "SearchStatementTimeoutSeconds": 20
      },
      "ServiceOwnerSearch": {
        "MaxPartyFilterValues": 20,
        "MaxServiceResourceFilterValues": 20,
        "MaxExtendedStatusFilterValues": 20
      }
    }
  },
  "WebApi": {
    "HealthCheckSettings": {
      "HttpGetEndpointsToCheck": [
        {
          "Name": "Altinn CDN",
          "Url": "https://altinncdn.no/orgs/altinn-orgs.json",
          "HardDependency": false
        },
        {
          "Name": "Altinn Access Management API",
          // TODO! Replace with health endpoint when available.
          "AltinnPlatformRelativePath": "accessmanagement/api/v1/meta/info/roles",
          "HardDependency": true
        }
        // TODO! Add PDP, Register when health endpoints are available.
      ]
    }
  },
  "AllowedHosts": "*"
}
