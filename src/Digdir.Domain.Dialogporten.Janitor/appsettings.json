{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Error",
        "Digdir.Domain.Dialogporten": "Information"
      }
    }
  },
  "Infrastructure": {
    "AltinnCdn": {
      "BaseUri": "https://altinncdn.no/"
    }
  },
  "MetricsAggregation": {
    "TT02WorkspaceId": "",
    "ProdWorkspaceId": "",
    "StorageConnectionString": "",
    "StorageContainerName": "dialogporten-metrics",
    "UsePrometheus": true,
    "SkipUpload": true,
    "PrometheusBaseUrl": "http://localhost:9090",
    "Environments": [ "Development" ]
  },
  "AllowedHosts": "*"
}
